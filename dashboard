# 1. 데이터 전처리
data_revised <- data %>% 
  filter(is.na(data$`3-1. 성/연령/입지유형별 이동량`) == FALSE)
names(data_revised)[1] <- "등록일자"
names(data_revised)[11:17] <- c("20세 미만", "20대", "30대", "40대", "50대", "60대", "70세 이상")
data_revised <- data_revised %>%
  select(등록일자, `20세 미만`, `20대`, `30대`, `40대`, `50대`, `60대`, `70세 이상`)
data_long <- data_revised %>%
  pivot_longer(cols = c("20세 미만", "20대", "30대", "40대", "50대", "60대", "70세 이상"), 
               names_to = "연령대", values_to = "이동량")
# 이동량을 숫자형으로 변환하고 월별 데이터 처리
data_monthly <- data_long %>%
  mutate(
    등록일자 = substr(등록일자, 1, 7),          # 연도와 월만 추출
    이동량 = as.numeric(이동량)                # 이동량을 숫자형으로 변환
  ) %>%
  group_by(등록일자, 연령대) %>%               # 월별, 연령대별 그룹화
  summarise(이동량 = sum(이동량, na.rm = TRUE)) %>%  # 이동량 합계
  ungroup()
data_monthly <- data_monthly %>%
  mutate(등록일자 = as.Date(paste0(등록일자, ".01"), format = "%Y.%m.%d"))
data_monthly <- data_monthly %>%
  mutate(연령대 = factor(연령대, levels = c("20세 미만", "20대", "30대", "40대", 
                                            "50대", "60대", "70세 이상")))
# 월별 이동량 추이 그래프
ggplot(data_monthly, aes(x = 등록일자, y = 이동량, color = 연령대)) +
  geom_line(size = 0.6) +
  labs(
    title = "연령대별 이동량 추이",
    x = "등록일자 (월별)",
    y = "이동량",
    color = "연령대"
  ) +
  theme_minimal() +
  theme(
    plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
    axis.text.x = element_text(angle = 45, hjust = 1)
  )
```
**노령층(70세 이상)의 이동량**이 다른 연령층에 비해 현저히 적음을 알 수 있다.
**노령층의 확진율이 다른 연령에 비해 낮은 이유**는 **노령층의 절대적인 이동량(통행량 또는 활동량)이 다른 연령층에 비해 적기 때문**이라 볼 수 있다.
