# [CH 1] 전국 확진자/사망자 추이 그래프
```{r}
library(ggplot2)
library(tidyverse)
library(scales) # 날짜 월별 표시를 위해 추가
# 기준일자 형식 변환 및 정렬
covid_df <- covid_df %>%
  mutate(
    기준일자 = as.Date(기준일자, format = "%Y%m%d"), # 기준일자 날짜 변환
    확진자수 = as.numeric(확진자수),  # 확진자수 숫자형 변환
    사망자수 = as.numeric(사망자수)   # 사망자수 숫자형 변환
  ) %>%
  arrange(기준일자) %>% 
  filter(!(기준일자 == as.Date("2023-06-07") & 사망자수 == 0))
# 그래프 그리기 (보조축 추가)
ggplot(covid_df, aes(x = 기준일자)) +
  geom_line(aes(y = 확진자수, color = "확진자수"), size = 1) +  # 확진자수 (Primary Y축)
  geom_line(aes(y = 사망자수 * 100, color = "사망자수"), size = 1) + # 사망자수 (Secondary Y축)
  scale_y_continuous(
    name = "확진자수",
    sec.axis = sec_axis(~ . / 100, name = "사망자수")  # 보조축 스케일 조정
  ) +
  scale_x_date(
    date_breaks = "3 months",   # 3개월 단위로 X축 레이블 설정
    date_labels = "%Y-%m"       # 연도-월 형식으로 표시
  ) +
  scale_color_manual(values = c("확진자수" = "blue", "사망자수" = "red")) +
  labs(
    title = "전국 COVID-19 확진자 및 사망자 추이",
    x = "기준일",
    y = "확진자수",
    color = "범례"
  ) +
  theme_minimal() +
  theme(
    axis.text.x = element_text(angle = 90, hjust = 1, vjust = 0.5),  # X축 레이블 세로 정렬
    plot.title = element_text(hjust = 0.5, size = 16, face = "bold") # 타이틀 가운데 정렬 및 강조
  )
```
**2022년 2월**을 기준으로 확진자 수가 급증하는 것을 알 수 있다. (**Why?**)  
