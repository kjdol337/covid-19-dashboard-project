### [CH 2-1-3] 시도별 K-means 클러스터링 (발생율, 확진자 수를 기준)
```{r}
# 1. 데이터 전처리: covid_시도_revised_df
covid_시도_revised2_df <- covid_시도_revised_df %>%
  mutate(
    누적확진자수 = as.numeric(누적확진자수),
    십만명당발생율 = as.numeric(십만명당발생율)
  )
covid_시도_revised2_df <- covid_시도_revised2_df %>%  # NA가 있는 행 제거
  filter(!is.na(십만명당발생율)) %>% 
  filter(시도명 != "검역")  # 검역 데이터는 제거
covid_시도_revised3_df <- covid_시도_revised2_df %>%
  group_by(시도명) %>%
  summarize(
    최신_확진자수 = last(누적확진자수[order(기준일자)]), # 가장 최근 누적확진자수
    평균_발생율 = median(십만명당발생율, na.rm = TRUE)       # 발생률은 중앙값으로 계산
  ) %>%
  ungroup()
# 2. 클러스터링 수행
# 클러스터링을 위한 데이터 정규화
scaled_data <- covid_시도_revised3_df %>%
  select(최신_확진자수, 평균_발생율) %>%
  scale()
# K-means 클러스터링
set.seed(42)
kmeans_result <- kmeans(scaled_data, centers = 3, nstart = 10)
covid_시도_revised3_df$클러스터 <- as.factor(kmeans_result$cluster)
# 3. 시도별 좌표 데이터 정의 및 병합
coordinates <- data.frame(
  시도명 = c("서울", "부산", "대구", "인천", "광주", "대전", "울산", 
           "세종", "경기", "강원", "충북", "충남", "전북", "전남", "경북", "경남", "제주"),
  경도 = c(126.977, 129.075, 128.601, 126.705, 126.853, 127.384, 129.312,
          127.289, 127.518, 128.204, 127.491, 126.672, 127.149, 126.463, 128.725, 128.064, 126.531),
  위도 = c(37.566, 35.179, 35.871, 37.456, 35.159, 36.35, 35.539,
          36.481, 37.263, 37.885, 36.635, 36.658, 35.821, 34.816, 36.576, 35.229, 33.499)
)
# 좌표 데이터를 기반으로 sf 객체 생성
shp <- st_as_sf(
  data.frame(
    시도명 = coordinates$시도명,
    geometry = st_sfc(
      mapply(function(lon, lat) st_point(c(lon, lat)), coordinates$경도, coordinates$위도, SIMPLIFY = FALSE)
    )
  )
)
# 병합
shp <- shp %>%
  left_join(covid_시도_revised3_df, by = "시도명")
# 4. 지도 시각화
ggplot(data = shp) +
  geom_sf(aes(fill = 클러스터, shape = 클러스터), color = "black", size = 4) + # 도형 크기 확대
  scale_fill_brewer(palette = "Set3") + # 클러스터별 색상 차이
  scale_shape_manual(values = c(21, 22, 23)) + # 클러스터별 도형 지정
  geom_text(aes(label = 시도명, geometry = geometry), 
            stat = "sf_coordinates", 
            nudge_y = 0.2, size = 2.5, color = "black") + # 글씨 크기 축소 및 위치 조정
  labs(
    title = "시도별 COVID-19 클러스터링",
    fill = "클러스터",
    shape = "클러스터"
  ) +
  theme_minimal()
# 5. 클러스터별 특징 분석
cluster_summary <- covid_시도_revised3_df %>%
  group_by(클러스터) %>%
  summarize(
    평균_최신_확진자수 = mean(최신_확진자수, na.rm = TRUE),
    평균_발생율 = mean(평균_발생율, na.rm = TRUE)
  )
print(cluster_summary)
```
**클러스터 1** : 수도권(서울, 경기) 지역으로 가장 높은 확진자 수와 발생율을 보인다.  
=> 방역과 감시가 중요한 **고위험 지역**이라고 할 수 있다.
