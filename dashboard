## [CH 2-2] 시도별 COVID-19 분석 (선별진료소, 사회적거리두기)
### [CH 2-2-1] 시도별 선별진료소 개수 (+확진자 수)
```{r}
# Step 1: 시도별 선별진료소 개수 데이터 준비
region_count <- covid_선별진료소_운영현황_df %>%
  group_by(시도명) %>%
  summarise(선별진료소_개수 = n())
# Step 2: 시도별로 가장 최신 누적확진자수 데이터 필터링
latest_case_data <- covid_시도_df %>%
  group_by(시도명) %>%
  slice_max(order_by = 기준일자, n = 1) %>% # 시도별 최신 날짜 데이터 선택
  ungroup() %>%
  select(시도명, 누적확진자수)
# Step 3: 각 시도명별로 누적확진자수가 가장 큰 행 선택
largest_case_data <- latest_case_data %>%
  group_by(시도명) %>%
  slice_max(order_by = 누적확진자수, n = 1) %>%
  ungroup() %>% 
  distinct() %>%
  filter(!시도명 %in% c("검역", "합계"))
# Step 4: 그래프 그리기
ggplot() +
  # 막대그래프: 선별진료소 개수 (왼쪽 Y축)
  geom_bar(data = region_count, 
           aes(x = reorder(시도명, -선별진료소_개수), y = 선별진료소_개수), 
           stat = "identity", fill = "royalblue", alpha = 0.7) +
  # 선그래프: 누적확진자수 (오른쪽 Y축)
  geom_line(data = largest_case_data, 
            aes(x = 시도명, y = as.numeric(누적확진자수) / 100000, group = 1), 
            color = "red", size = 1.2) +
  geom_point(data = largest_case_data, 
             aes(x = 시도명, y = as.numeric(누적확진자수) / 100000), 
             color = "red", size = 2) +
  # Y축 설정: 왼쪽과 오른쪽 Y축 별도 설정
  scale_y_continuous(
    name = "선별진료소 개수", 
    sec.axis = sec_axis(~ . * 1000, name = "누적확진자수 (십만 단위)") # 오른쪽 Y축
  ) +
  # 라벨 및 제목
  labs(
    title = "시도별 누적확진자수(십만 단위)와 선별진료소 개수",
    x = "시도명"
  ) +
