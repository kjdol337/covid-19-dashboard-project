# [CH 0] SQL에 저장해 두었던 API 데이터를 RMD로 불러오기 
```{r}
library(DBI)
library(odbc)
con <- dbConnect(odbc::odbc(),
                 Driver   = "MySQL ODBC 8.0 Unicode Driver",
                 Server   = "localhost",
                 Database = "my_covid19",  # 새로 만든 데이터베이스 이름
                 UID      = "root",
                 PWD      = Sys.getenv("DB_PASSWORD"), # 실제 비밀번호 삭제
                 Port     = 3306)
# SQL 테이블 불러오기
covid_df <- dbGetQuery(con, "SELECT * FROM covid19_data")  # SQL 테이블(covid19_data) 불러오기
covid_시도_df <- dbGetQuery(con, "SELECT * FROM covid19_시도")  # SQL 테이블(covid19_시도) 불러오기
covid_성별_연령별_df <- dbGetQuery(con, "SELECT * FROM covid19_성별_연령별")  # SQL 테이블(covid19_성별_연령별) 불러오기
covid_선별진료소_운영현황_df <- dbGetQuery(con, "SELECT * FROM covid19_선별진료소_운영현황")  # SQL 테이블(covid19_선별진료소_운영현황) 불러오기
covid_사회적거리두기현황_df <- dbGetQuery(con, "SELECT * FROM covid19_사회적거리두기현황")  # SQL 테이블(covid19_사회적거리두기현황) 불러오기
# MySQL 연결 종료
dbDisconnect(con)
```
