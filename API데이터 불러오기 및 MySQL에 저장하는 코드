# <코로나19 감염현황 총괄 통계 API>
# API 설정
serviceUrl <- "http://apis.data.go.kr/1352000/ODMS_COVID_02"
oper_serve <- "/callCovid02Api"
my_key <- "YOUR_API_KEY_HERE"

# 초기 설정
pageNo <- 1       # 페이지 번호
rows <- 500       # 한 페이지당 데이터 수

# 전체 데이터 수 확인
url <- paste0(serviceUrl, oper_serve,
              "?serviceKey=", my_key,
              "&numOfRows=", rows,
              "&pageNo=", pageNo)

# 첫 번째 요청으로 totalCount 추출
response <- GET(url)
xml_data <- xmlParse(response)
rootNode <- xmlRoot(xml_data)

# 전체 데이터 수 가져오기
totalCount <- as.numeric(xpathSApply(rootNode, "//totalCount", xmlValue))
cat("전체 데이터 수: ", totalCount, "\n")

# 반복 횟수 계산
loopCount <- ceiling(totalCount / rows)
cat("반복할 페이지 수: ", loopCount, "\n")

# 최종 데이터를 저장할 빈 데이터프레임 생성
final_data <- data.frame()

# 반복문을 사용해 모든 데이터 가져오기
for (i in 1:loopCount) {
  cat("페이지 ", i, " 처리 중...\n")
  
  # URL 생성
  url <- paste0(serviceUrl, oper_serve,
                "?serviceKey=", my_key,
                "&numOfRows=", rows,
                "&pageNo=", i)
  
  # XML 데이터 파싱
  response <- GET(url)
  xml_data <- xmlParse(response)
  rootNode <- xmlRoot(xml_data)
  
  # items 노드에서 데이터 추출
  page_data <- xmlToDataFrame(nodes = getNodeSet(rootNode, "//items/item"))
  
  # 데이터를 결합
  final_data <- rbind(final_data, page_data)
}

final_data <- final_data %>% distinct()

covid_df <- final_data %>% 
  rename(
    누적확진율=accDefRate,
    누적검사수=accExamCnt,
    누적검사완료수=accExamCompCnt,
    치료중환자수=careCnt,
    격리해제수=dPntCnt,
    사망자수=gPntCnt,
    확진자수=hPntCnt,
    결과음성수=resutlNegCnt,
    기준일자=statusDt,
    기준시간=statusTime,
    검사중수=uPntCnt
  )


