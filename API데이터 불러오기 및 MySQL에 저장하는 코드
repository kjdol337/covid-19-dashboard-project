#SQL과 연동
install.packages("DBI")
install.packages("odbc")

library(DBI)
library(odbc)

con <- dbConnect(odbc::odbc(),
                 Driver   = "MySQL ODBC 8.0 Unicode Driver",
                 Server   = "localhost",
                 Database = "my_covid19",  # 새로 만든 데이터베이스 이름
                 UID      = "root",
                 PWD      = "YOUR_PASSWORD",
                 Port     = 3306)

print("Connection Successful!")


# covid_df 데이터프레임을 SQL 테이블로 저장
